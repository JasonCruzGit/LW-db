# Optional: call the API directly from the browser (bypasses Next rewrites). Needed for CORS on the API.
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Vercel / production: set this in the Vercel dashboard to your Express deployment URL (no trailing path).
# Example: API_PROXY_TARGET=https://lw-api-production.up.railway.app
# Or use NEXT_PUBLIC_API_URL to that same URL instead (and set server WEB_ORIGIN to your Vercel app URL).
