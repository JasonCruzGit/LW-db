# Supabase → Project Settings → Database
# Use "Transaction pooler" (port 6543) for the app; "Direct connection" or Session pooler :5432 for migrations.
# If you use only the direct URI for both, set DATABASE_URL and DIRECT_URL to the same string.
#
# Encode special characters in the password (e.g. @ → %40).
#
# Transaction pooler (recommended for Prisma + long-running API):
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Direct (migrations / db push — use host from "Direct connection" in dashboard, often db.[PROJECT-REF].supabase.co:5432):
# DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

JWT_SECRET="change-me-in-production-use-long-random-string"
PORT=4000
WEB_ORIGIN="http://localhost:3000"
