# Supabase → Connect → Connection string
#
# DATABASE_URL: use Transaction pooler, port 6543 (required for Prisma from Railway/Vercel-style hosts).
# DIRECT_URL: Direct connection for prisma migrate / db push (db.PROJECT.supabase.co:5432).
#
# Encode special characters in the password (e.g. @ → %40).
# The server adds sslmode=require (and pgbouncer params on :6543) automatically — you can omit query params here.

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

JWT_SECRET="change-me-in-production-use-long-random-string"
PORT=4000
WEB_ORIGIN="http://localhost:3000"
