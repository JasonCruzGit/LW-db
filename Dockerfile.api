# API image — build from monorepo root: docker build -f Dockerfile.api -t lw-api .
FROM node:22-bookworm-slim AS runner
WORKDIR /app

COPY package.json package-lock.json ./
COPY server ./server

# Need devDependencies for `prisma` CLI during generate + `tsc` (or use multi-stage prune later).
RUN npm ci --workspace=server

WORKDIR /app/server
RUN npx prisma generate && npm run build

ENV NODE_ENV=production
EXPOSE 4000
CMD ["node", "dist/index.js"]
